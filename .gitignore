# =============================================================
# Capstone Project — .gitignore
# =============================================================

# --- System Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# --- Python Cache ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# --- Virtual Environments ---
venv/
.venv/
env/
ENV/
.env
*.egg-info/
dist/
build/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Large Raw Data Files (too large for GitHub) ---
Data/creditcard.csv
*.csv
*.zip
*.tar.gz
*.gz
*.sqlite
*.db

# --- Preprocessed / Serialized Model Artifacts (large binary files) ---
Python files/preprocessed_data/
*.pkl
*.pickle
*.keras
*.h5
*.pt
*.pth
*.onnx

# --- Sensitive Credentials ---
kaggle.json
*.json
!package.json

# --- IDE & Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code settings ---
.claude/
